# Anmeldung bei Lidl Connect
RUFNUMMER="0XXXXXXXXX"          # RUFNUMMER mit 0 am Anfang
PASSWORD="DEIN_PASSWORT"        # Passwort für die Anmeldung bei Lidl Connect

# Browserwahl: "firefox", "webkit" oder "chromium" (Standard: "firefox")
BROWSER="firefox"

# Telegram-Benachrichtigungen
TELEGRAM_ALLOW=false            # Kann "true" oder "false" sein
TELEGRAM_TOKEN=""               # Token für den Telegram Bot
TELEGRAM_CHAT_ID=""             # Chat-ID für den Telegram Bot

# Discord-Benachrichtigungen
DISCORD_ALLOW=false             # Kann "true" oder "false" sein
DISCORD_WEBHOOK_URL=""          # Webhook-URL für Discord

# Existierende Browser-Prozesse beim Start killen?
# WARNUNG: Das killt ALLE Browser-Prozesse (Chrome/Firefox/etc), nicht nur von diesem Script!
# Nur aktivieren wenn du keine anderen Scripts parallel laufen hast
KILL_EXISTING_PROCESSES=true   # Kann "true" oder "false" sein

# Existierende script.js-Instanzen beim Start killen?
# Hilfreich wenn das Script mit 100% CPU im Hintergrund hängt
# Killt alte Prozesse außer dem aktuellen
KILL_SCRIPT_INSTANCES=true     # Kann "true" oder "false" sein

# Auto-Update des Scripts
AUTO_UPDATE=true                # Kann "true" oder "false" sein

# Schlafmodus: "random", "fixed" oder "smart"
SLEEP_MODE="smart"

# Log-Level: "info", "warn" oder "error"
INFOLEVEL="info"
